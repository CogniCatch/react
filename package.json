{
  "name": "@cognicatch/react",
  "version": "1.2.2",
  "description": "GenUI Error Boundaries and AI Recovery UIs for React",
  "private": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CogniCatch/react.git"
  },
